# ── Kore Framework — Variables de entorno ──
# Copia este archivo a .env y completa los valores
# El instalador web (/setup) puede generar este archivo automáticamente

# Estado de instalación (false = pendiente de configuración web)
KORE_INSTALLED=false

# Información del proyecto
PROJECT_NAME=Kore App
PROJECT_URL=https://misitio.cl
PORT=3001

# Cuenta Kapitán (superadmin) — se completa durante /setup
KAPITAN_USER=
KAPITAN_PASS=

# Secreto de sesión (generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
SESSION_SECRET=

# IA — Claude API (Anthropic)
# Obtener en: https://console.anthropic.com
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Base de datos
DB_PATH=./db/database.sqlite
BACKUP_DIR=./db/backups

# Push Notifications (opcional)
VAPID_PUBLIC=
VAPID_PRIVATE=

# Telegram Bot (opcional)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Google Maps (opcional)
GOOGLE_MAPS_KEY=