{
  "env": {
    "node": true,
    "es2022": true,
    "browser": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "commonjs"
  },
  "extends": ["eslint:recommended"],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "no-constant-condition": "off",
    "no-prototype-builtins": "off",
    "prefer-const": "warn",
    "no-var": "error",
    "eqeqeq": ["warn", "smart"]
  },
  "ignorePatterns": [
    "node_modules/",
    "db/",
    "uploads/",
    "public/",
    "logs/",
    "*.min.js"
  ]
}